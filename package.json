{
  "name": "@willow-network/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Willow - Cryptographically authenticated storage platform",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "willow",
    "blockchain",
    "storage",
    "did",
    "cryptographic-proofs"
  ],
  "author": "Willow Team",
  "license": "MIT",
  "dependencies": {
    "@noble/ciphers": "^1.3.0",
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.4.0",
    "axios": "^1.6.2",
    "blake3": "^2.1.7",
    "ethers": "^6.9.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.4",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/willow-network/willow-sdk-typescript.git"
  }
}
