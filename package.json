{
  "name": "@willow-network/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Willow — verifiable indexed-data storage with client-side Merkle proof verification",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "grovedb": [
        "./dist/grovedb.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./grovedb": {
      "import": {
        "types": "./dist/grovedb.d.mts",
        "default": "./dist/grovedb.mjs"
      },
      "require": {
        "types": "./dist/grovedb.d.ts",
        "default": "./dist/grovedb.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "npm run build"
  },
  "keywords": [
    "willow",
    "blockchain",
    "storage",
    "did",
    "merkle-proof",
    "verifiable-data",
    "cryptographic-proofs"
  ],
  "author": "Willow",
  "license": "MIT",
  "homepage": "https://willow.tech",
  "bugs": {
    "url": "https://github.com/willow-network/willow-sdk-typescript/issues"
  },
  "dependencies": {
    "@noble/ciphers": "^1.3.0",
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.4.0",
    "ethers": "^6.9.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.4",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "ws": "^8.21.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/willow-network/willow-sdk-typescript.git"
  }
}
